# =============================================================================
# Environment Variables — Example Configuration
# =============================================================================
#
# This file documents all environment variables used by the project with
# placeholder values. Copy it to .env and fill in real values for local
# development.
#
# For production credentials managed through 1Password, see env-template.tpl
# which uses op:// references. See docs/SECRETS.md for details.
#
# IMPORTANT: .env is gitignored. Never commit real credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_BASE_URL=https://api.example.com
API_VERSION=v1

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
ANALYTICS_KEY=your-analytics-key-here
ANALYTICS_ENABLED=true

# -----------------------------------------------------------------------------
# Firebase (if applicable)
# -----------------------------------------------------------------------------
# iOS: GoogleService-Info.plist handles Firebase config
# Android: google-services.json handles Firebase config
# These env vars are for server-side or shared tooling only
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_API_KEY=your-firebase-api-key

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_ONBOARDING=true
FEATURE_DARK_MODE=true
FEATURE_PUSH_NOTIFICATIONS=false

# -----------------------------------------------------------------------------
# Debug Settings
# -----------------------------------------------------------------------------
DEBUG_LOGGING=true
DEBUG_NETWORK_INSPECTOR=false
MOCK_API=false
